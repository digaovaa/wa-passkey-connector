{
  "name": "wa-passkey-connector",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser extension that imports an authenticated WhatsApp Web session into your app to pair a passkey-locked account (MV3).",
  "license": "Unlicense",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "pack": "npm run build && crx3 dist -o wa-passkey-connector.crx -p key.pem",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "crx3": "^1.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
